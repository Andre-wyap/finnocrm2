# ─── PostgreSQL (Hostinger VPS) ───────────────────────────────────────────────
# DATABASE_URL uses app_user (RLS enforced).
# DATABASE_URL_INTAKE uses intake_role (bypasses RLS — intake endpoint only).
# Neither should be the postgres superuser.
DATABASE_URL=postgresql://app_user:<password>@<vps-ip>:5432/finno_crm?sslmode=require
DATABASE_URL_INTAKE=postgresql://intake_role:<password>@<vps-ip>:5432/finno_crm?sslmode=require

# ─── Firebase Admin SDK (server-side only — never expose to the browser) ───────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Copy the private_key value from the downloaded service account JSON exactly — keep the \n escapes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Firebase client SDK (safe to expose — bundled in the browser) ─────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
# Optional. Invite links default to 24 hours if this is omitted.
USER_INVITE_TTL_HOURS=24
# Optional but recommended. Generate with: openssl rand -hex 32
# Falls back to the Firebase private key if omitted.
USER_INVITE_SECRET=

# ─── AI assistant / 21st SDK (server-side only) ───────────────────────────────
API_KEY_21ST=

# Shared secret sent by Elementor in the X-Intake-Secret header.
# Generate with: openssl rand -hex 32
# Paste the same value into Elementor Pro → form → Actions → Webhook → custom header.
INTAKE_SECRET=
